{% assign first_day = calendar.first %}

<div class="layout layout--col h--full w--full" style="padding: 10px 10px 8px; background:#111111; color:#f5f1e8;">
  <div style="font-size:16px; line-height:1; letter-spacing:-0.04em; font-weight:900; color:#fffdf8; padding-bottom:6px; border-bottom:1px solid #f0ebe2; margin-bottom:8px;">Upcoming</div>

  {% if first_day %}
  <div style="display:grid; grid-template-columns:48px minmax(0, 1fr); gap:8px; align-items:start; flex:1;">
    <div style="padding-top:2px;">
      {% assign day_number = first_day.date | slice: 0, 2 %}
      {% assign day_label = first_day.date | remove_first: day_number | strip %}
      <div style="font-size:24px; line-height:0.86; font-weight:900; letter-spacing:-0.05em; color:#fffdf8;">{{ day_number }}</div>
      <div style="font-size:8px; line-height:1.05; text-transform:uppercase; letter-spacing:0.08em; color:#d8c9a2; font-weight:800;">{{ day_label }}</div>
    </div>
    <div style="display:flex; flex-direction:column; gap:6px; min-width:0;">
      {% for event in first_day.events limit:2 %}
      <div style="display:grid; grid-template-columns:4px minmax(0, 1fr); gap:7px; align-items:start;">
        <div style="width:4px; min-height:26px; border-radius:99px; background:{{ event.source_color | default: 'black' }};"></div>
        <div style="display:flex; flex-direction:column; gap:2px; min-width:0;">
          <div style="font-size:12px; line-height:0.95; font-weight:900; letter-spacing:-0.03em; color:#fffdf8;">{{ event.summary }}</div>
          {% if event.start %}
          <div style="font-size:8px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:#d8c9a2; font-weight:800;">{{ event.start }}</div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
      {% if first_day.hidden_events and first_day.hidden_events > 0 %}
      <div style="font-size:8px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:#d8c9a2; font-weight:900;">+{{ first_day.hidden_events }} more</div>
      {% endif %}
    </div>
  </div>
  {% endif %}
</div>
