{% assign theme_mode = trmnl.plugin_settings.custom_fields_values.theme | default: theme | default: 'dark' %}
{% assign layout_style = trmnl.plugin_settings.custom_fields_values.layout_style | default: layout_style | default: 'editorial' %}
{% if theme_mode == 'light' %}
  {% assign page_bg = '#f6f1e8' %}
  {% assign page_fg = '#141414' %}
  {% assign panel_border = '#d5ccbf' %}
  {% assign panel_bg = '#fffdfa' %}
  {% assign rail_bg = '#ece3d7' %}
  {% assign accent_text = '#6f6558' %}
  {% assign primary_text = '#131313' %}
  {% assign secondary_text = '#786d60' %}
  {% assign strong_line = '#121212' %}
  {% assign chip_text = '#4c443b' %}
{% else %}
  {% assign page_bg = '#111111' %}
  {% assign page_fg = '#f5f1e8' %}
  {% assign panel_border = '#3b352d' %}
  {% assign panel_bg = '#1a1a1a' %}
  {% assign rail_bg = '#24211d' %}
  {% assign accent_text = '#d8c9a2' %}
  {% assign primary_text = '#fffdf8' %}
  {% assign secondary_text = '#d8c9a2' %}
  {% assign strong_line = '#f0ebe2' %}
  {% assign chip_text = '#ece5da' %}
{% endif %}

<div class="layout layout--col h--full w--full" style="padding: 16px 20px 10px; background:{{ page_bg }}; color:{{ page_fg }};">
  <div style="display:grid; grid-template-columns: 1fr auto; gap:16px; align-items:end; border-bottom:3px solid {{ strong_line }}; padding-bottom:8px; margin-bottom:14px;">
    <div style="display:flex; flex-direction:column; gap:2px;">
      <div style="font-size:10px; line-height:1; letter-spacing:0.25em; text-transform:uppercase; color:{{ accent_text }}; font-weight:800;">{{ title | default: 'Calendar' }}</div>
      <div style="font-size:32px; line-height:0.85; letter-spacing:-0.04em; font-weight:900; color:{{ primary_text }};">Upcoming Agenda</div>
    </div>
    <div style="font-size:10px; line-height:1.2; letter-spacing:0.1em; text-transform:uppercase; color:{{ accent_text }}; font-weight:800; text-align:right;">Refreshed {{ updated_at }}</div>
  </div>

  <div style="display:grid; grid-template-columns: repeat({{ columns | default: 2 }}, minmax(0, 1fr)); gap:12px 18px; align-content:start; flex:1; width:100%;">
    {% for day in calendar %}
    <div style="display:flex; flex-direction:column; gap:6px; padding-bottom:10px; border-bottom:1px solid {{ panel_border }};">
      {% assign date_parts = day.date | split: ' ' %}
      {% assign day_num = date_parts[0] %}
      {% assign month_name = date_parts[1] %}
      {% assign weekday_name = date_parts[2] %}

      <div style="display:flex; align-items:baseline; gap:8px;">
        <span style="font-size:28px; font-weight:900; line-height:0.8; letter-spacing:-0.05em; color:{{ primary_text }};">{{ day_num }}</span>
        <div style="display:flex; flex-direction:column;">
          <span style="font-size:10px; font-weight:800; line-height:1; text-transform:uppercase; letter-spacing:0.05em; color:{{ accent_text }};">{{ month_name }}</span>
          <span style="font-size:10px; font-weight:900; line-height:1; text-transform:uppercase; letter-spacing:0.05em; color:{{ primary_text }};">{{ weekday_name | remove: '(' | remove: ')' }}</span>
        </div>
        {% if highlight_today and forloop.first %}
        <span style="margin-left:auto; background:{{ primary_text }}; color:{{ page_bg }}; font-size:9px; font-weight:900; padding:2px 6px; border-radius:4px; text-transform:uppercase; letter-spacing:0.1em;">Today</span>
        {% endif %}
      </div>

      <div style="display:flex; flex-direction:column; gap:6px; margin-top:2px;">
        {% for event in day.events %}
        <div style="display:grid; grid-template-columns:3px 1fr; gap:8px; align-items:start;">
          <div style="width:3px; height:100%; min-height:22px; background:{{ event.source_color | default: 'black' }}; border-radius:2px;"></div>
          <div style="display:flex; flex-direction:column; gap:1px; min-width:0;">
            <div style="font-size:14px; font-weight:800; line-height:1.1; letter-spacing:-0.01em; color:{{ primary_text }}; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">{{ event.summary }}</div>
            <div style="display:flex; align-items:center; gap:6px;">
              {% if event.all_day %}
              <span style="font-size:9px; font-weight:900; line-height:1; text-transform:uppercase; letter-spacing:0.08em; color:{{ secondary_text }};">All Day</span>
              {% else %}
              <span style="font-size:9px; font-weight:900; line-height:1; text-transform:uppercase; letter-spacing:0.08em; color:{{ secondary_text }};">{{ event.start }}{% if event.end %} - {{ event.end }}{% endif %}</span>
              {% endif %}

              {% if show_source_labels %}
              <span style="font-size:9px; font-weight:700; line-height:1; color:{{ accent_text }}; opacity:0.8;">• {{ event.source_label }}</span>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
        
        {% if day.hidden_events > 0 %}
        <div style="font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:0.05em; color:{{ accent_text }}; margin-left:11px;">+ {{ day.hidden_events }} more</div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</div>
