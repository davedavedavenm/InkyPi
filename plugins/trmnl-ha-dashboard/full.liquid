{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}

<style>
  * { color-profile: srgb; }
  img { color-profile: srgb; }
</style>
<div class="layout layout--col h--full w--full" style="padding: 0; gap: 0; background: #000000; font-family: 'Courier New', monospace;">

  <!-- WEATHER — Blue panel, top-left -->
  <div style="flex: 1; display: flex; width: 100%;">
    <div style="width: 42%; background: #0000FF; padding: 20px 22px; display: flex; flex-direction: column; justify-content: center; gap: 12px;">
      <div style="font-size: 15px; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; color: #FFFF00;">Weather</div>
      <div style="font-size: 120px; font-weight: 900; line-height: 0.8; color: #FFFFFF; letter-spacing: -0.04em;">{{ weather.temperature | round }}<span style="font-size: 48px; vertical-align: super;">°</span></div>
      <div style="font-size: 26px; font-weight: 900; text-transform: uppercase; color: #FFFF00; letter-spacing: -0.02em;">{{ weather.condition | replace: "-", " " }}</div>
      <div style="font-size: 16px; font-weight: 900; color: #FFFFFF; letter-spacing: 0.04em; margin-top: 4px;">{{ weather.humidity }}% HUM &middot; {{ weather.wind_speed | round }} KM/H</div>
    </div>

    <!-- FAMILY — Red panel, top-right -->
    <div style="flex: 1; background: #FF0000; padding: 20px 24px; display: flex; flex-direction: column; justify-content: center;">
      <div style="font-size: 13px; font-weight: 900; letter-spacing: 0.25em; text-transform: uppercase; color: #FFFF00;">Presence</div>
      {% for person in people %}
      <div style="display: flex; align-items: baseline; gap: 14px; margin-top: 18px;">
        <div style="font-size: 42px; font-weight: 900; color: #FFFFFF; letter-spacing: -0.02em; line-height: 1;">{{ person.name }}</div>
        <div style="font-size: 18px; font-weight: 900; text-transform: uppercase; background: #000000; color: {% if person.state == 'home' %}#00FF00{% elsif person.state == 'not_home' %}#FF0000{% else %}#FFFF00{% endif %}; padding: 6px 14px; letter-spacing: 0.1em; vertical-align: middle;">{{ person.state | replace: "not_home", "AWAY" }}</div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Bottom row -->
  <div style="flex: 1; display: flex; width: 100%;">
    <!-- HOME — Black panel with green highlights, bottom-left -->
    <div style="width: 42%; background: #000000; padding: 20px 22px; display: flex; flex-direction: column; justify-content: center;">
      <div style="font-size: 13px; font-weight: 900; letter-spacing: 0.25em; text-transform: uppercase; color: #00FF00;">Home</div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 14px; padding-bottom: 8px; border-bottom: 2px solid #00FF00;">
        <span style="font-size: 20px; font-weight: 900; color: #FFFFFF;">DOOR</span>
        <span style="font-size: 18px; font-weight: 900; text-transform: uppercase; color: {% if home.door_locked %}#00FF00{% else %}#FF0000{% endif %};">{% if home.door_locked %}LOCKED{% else %}OPEN{% endif %}</span>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px; padding-bottom: 8px; border-bottom: 2px solid #00FF00;">
        <span style="font-size: 20px; font-weight: 900; color: #FFFFFF;">LAUNDRY</span>
        <span style="font-size: 18px; font-weight: 900; text-transform: uppercase; color: {% if home.washer_running %}#FFFF00{% else %}#FFFFFF{% endif %};">{% if home.washer_running %}ON{% else %}OFF{% endif %}</span>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px; padding-bottom: 8px; border-bottom: 2px solid #00FF00;">
        <span style="font-size: 20px; font-weight: 900; color: #FFFFFF;">TEMP</span>
        <span style="font-size: 24px; font-weight: 900; color: #FFFF00;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°{% else %}--°{% endif %}</span>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
        <span style="font-size: 20px; font-weight: 900; color: #FFFFFF;">BLINDS</span>
        <span style="font-size: 18px; font-weight: 900; text-transform: uppercase; color: #FFFFFF;">{% if home.blind_position == "100" %}OPEN{% else %}CLOSED{% endif %}</span>
      </div>
    </div>

    <!-- SONOS — Orange panel, bottom-right -->
    <div style="flex: 1; background: #FFA500; padding: 20px 22px; display: flex; flex-direction: column; justify-content: center; gap: 10px;">
      <div style="font-size: 15px; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; color: #000000;">Sonos</div>
      {% if active_sonos %}
        {% if active_sonos.picture %}
        <div style="width: 140px; height: 140px; border-radius: 4px; overflow: hidden; border: 3px solid #000000;">
          <img src="{{ active_sonos.picture }}" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        {% endif %}
        <div style="font-size: 14px; font-weight: 900; text-transform: uppercase; color: #000000; letter-spacing: 0.1em;">{{ active_sonos.room }}</div>
        <div style="font-size: 24px; font-weight: 900; color: #000000; line-height: 1.1;">{{ active_sonos.title }}</div>
        <div style="font-size: 18px; font-weight: 900; color: #000000;">{{ active_sonos.artist }}</div>
      {% else %}
        <div style="display: flex; flex-direction: column; gap: 6px;">
          <div style="font-size: 22px; font-weight: 900; color: #000000; text-transform: uppercase; letter-spacing: 0.06em;">No Music</div>
          {% assign idle_count = sonos | where: "state", "idle" | size %}
          {% if idle_count > 0 %}
          <div style="font-size: 16px; font-weight: 900; color: #000000; text-transform: uppercase; letter-spacing: 0.04em;">{{ idle_count }} ROOM{% if idle_count > 1 %}S{% endif %} IDLE</div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Timestamp overlay -->
  <div style="position: absolute; bottom: 8px; right: 14px; font-size: 11px; font-weight: 900; color: #FFFF00; letter-spacing: 0.1em;">{{ updated_at }}</div>

</div>
