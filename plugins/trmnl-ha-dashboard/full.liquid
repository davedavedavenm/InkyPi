{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}
{% assign idle_count = sonos | where: "state", "idle" | size %}

<!--
  Spectra: #000000 #FFFFFF #52180A #59683F #28487B #968327
  All backgrounds inline to avoid LaraPaper CSS conflicts.
-->

<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Helvetica Neue','Segoe UI',Arial,sans-serif; }
</style>

<!-- ROOT -->
<div style="width:800px;height:480px;display:flex;flex-direction:column;background:#f5f0e6;color:#000;">

  <!-- HEADER -->
  <div style="height:40px;flex-shrink:0;background:#000;display:flex;align-items:center;justify-content:space-between;padding:0 22px;">
    <span style="font-size:11px;font-weight:900;letter-spacing:4px;text-transform:uppercase;color:#fff;">Home Dashboard</span>
    <span style="font-size:11px;font-weight:700;color:#968327;letter-spacing:1px;">{{ updated_at }}</span>
  </div>

  <!-- CONTENT: full-width padding box -->
  <div style="flex:1;display:flex;gap:10px;padding:10px;min-height:0;">

    <!-- LEFT: WEATHER — navy card -->
    <div style="width:195px;flex-shrink:0;background:#28487B;border-radius:10px;display:flex;flex-direction:column;justify-content:space-between;padding:16px 18px;">
      <div>
        <div style="font-size:9px;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:#968327;margin-bottom:10px;">Weather</div>
        <div style="font-size:90px;font-weight:900;line-height:0.82;letter-spacing:-6px;color:#fff;">{{ weather.temperature | round }}<span style="font-size:38px;font-weight:200;vertical-align:super;letter-spacing:0;">°</span></div>
        <div style="font-size:28px;margin-top:10px;line-height:1;">
          {% assign c = weather.condition | downcase %}
          {% if c contains "clear" or c contains "sun" %}☀️{% elsif c contains "rain" or c contains "drizzle" or c contains "shower" %}🌧️{% elsif c contains "snow" or c contains "sleet" %}❄️{% elsif c contains "thunder" %}⛈️{% elsif c contains "fog" or c contains "mist" %}🌫️{% elsif c contains "cloud" or c contains "overcast" %}☁️{% else %}🌤️{% endif %}
        </div>
        <div style="font-size:15px;font-weight:800;color:#fff;margin-top:6px;text-transform:capitalize;">{{ weather.condition | replace: "-", " " }}</div>
      </div>
      <div style="font-size:11px;font-weight:600;color:#968327;line-height:1.5;">
        {{ weather.humidity }}% humidity<br>{{ weather.wind_speed | round }} km/h
      </div>
    </div>

    <!-- RIGHT STACK -->
    <div style="flex:1;display:flex;flex-direction:column;gap:10px;min-width:0;">

      <!-- TOP ROW: People + Home Status -->
      <div style="flex:1;display:flex;gap:10px;min-height:0;">

        <!-- PEOPLE — olive card -->
        <div style="flex:1;background:#59683F;border-radius:10px;padding:14px 16px;display:flex;flex-direction:column;">
          <div style="font-size:9px;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:#968327;border-bottom:1px solid rgba(255,255,255,0.2);padding-bottom:7px;margin-bottom:10px;">People</div>
          {% for person in people %}
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.1);">
            <span style="font-size:26px;font-weight:900;letter-spacing:-1.5px;color:#fff;">{{ person.name }}</span>
            <span style="display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:4px;background:{% if person.state == 'home' %}#000000{% else %}#52180A{% endif %};">
              <span style="width:6px;height:6px;border-radius:50%;background:#968327;flex-shrink:0;display:inline-block;"></span>
              <span style="font-size:9px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#fff;">{% if person.state == 'home' %}Home{% else %}Away{% endif %}</span>
            </span>
          </div>
          {% endfor %}
        </div>

        <!-- HOME STATUS — 2×2 card grid -->
        <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:8px;">

          <!-- DOOR -->
          <div style="background:#fff;border:3px solid {% if home.door_locked %}#28487B{% else %}#52180A{% endif %};border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#aaa;">🔒 Door</div>
            <div style="font-size:20px;font-weight:900;color:{% if home.door_locked %}#28487B{% else %}#52180A{% endif %};">{% if home.door_locked %}Locked{% else %}OPEN{% endif %}</div>
          </div>

          <!-- WASHER -->
          <div style="background:#fff;border:3px solid {% if home.washer_running %}#968327{% else %}#ddd{% endif %};border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#aaa;">👕 Washer</div>
            <div style="font-size:20px;font-weight:900;color:{% if home.washer_running %}#968327{% else %}#000{% endif %};">{% if home.washer_running %}Running{% else %}Off{% endif %}</div>
          </div>

          <!-- THERMOSTAT -->
          <div style="background:#fff;border:3px solid #ddd;border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#aaa;">🌡️ Thermostat</div>
            <div style="font-size:20px;font-weight:900;color:#000;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°C{% else %}--{% endif %}</div>
          </div>

          <!-- BLINDS -->
          <div style="background:#fff;border:3px solid {% if home.blind_position == 100 %}#59683F{% elsif home.blind_position == 0 %}#52180A{% else %}#ddd{% endif %};border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#aaa;">🪟 Blinds</div>
            <div style="font-size:20px;font-weight:900;color:#000;">{% if home.blind_position == "unavailable" or home.blind_position == nil %}--{% else %}{{ home.blind_position }}%{% endif %}</div>
          </div>

        </div>

      </div>

      <!-- BOTTOM: SONOS strip -->
      <div style="height:88px;flex-shrink:0;background:{% if active_sonos %}#968327{% else %}#52180A{% endif %};border-radius:10px;display:flex;align-items:center;gap:18px;padding:0 20px;">
        <span style="font-size:28px;flex-shrink:0;">{% if active_sonos %}🎵{% else %}🔇{% endif %}</span>
        <div style="flex:1;min-width:0;">
          <div style="font-size:9px;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:3px;">Sonos</div>
          {% if active_sonos %}
            <div style="font-size:20px;font-weight:900;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ active_sonos.title }}</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.7);margin-top:2px;">{{ active_sonos.artist }}{% if active_sonos.room %} &middot; {{ active_sonos.room }}{% endif %}</div>
          {% else %}
            <div style="font-size:20px;font-weight:900;color:#fff;">No Music Playing</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.65);margin-top:2px;">{{ idle_count }} room{% if idle_count != 1 %}s{% endif %} idle</div>
          {% endif %}
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:5px;align-self:center;max-width:185px;justify-content:flex-end;">
          {% for room in sonos %}
            <div style="font-size:8px;font-weight:900;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border-radius:4px;border:2px solid {% if room.state == 'playing' or room.state == 'paused' %}rgba(255,255,255,0.9){% else %}rgba(255,255,255,0.25){% endif %};color:{% if room.state == 'playing' or room.state == 'paused' %}#fff{% else %}rgba(255,255,255,0.35){% endif %};">{{ room.room | truncate: 10, "" }}</div>
          {% endfor %}
        </div>
      </div>

    </div>

  </div>

</div>
