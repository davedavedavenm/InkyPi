{
  "plugin_id": "trmnl-ha-dashboard",
  "name": "HA Dashboard",
  "version": "2.11.0",
  "fields": [
    {
      "key": "dashboard_title",
      "type": "text",
      "required": false,
      "default": "Home Assistant",
      "description": "Dashboard metadata title for plugin management and compatible renderers. The colour sidecar does not render a top bar."
    },
    {
      "key": "instance_label",
      "type": "text",
      "required": false,
      "default": "Home",
      "description": "Short label for the installed dashboard instance."
    },
    {
      "key": "layout_variant",
      "type": "text",
      "required": false,
      "default": "compact_grid",
      "allowed_values": ["compact_grid"],
      "description": "Layout family. The current colour sidecar compact_grid has no top bar, no bottom navigation, no visible lights, a combined climate/humidity card, grouped people, and no energy card."
    },
    {
      "key": "colour_profile",
      "type": "text",
      "required": false,
      "default": "inky_spectra_7",
      "allowed_values": ["inky_spectra_7"],
      "description": "Renderer colour profile. Use inky_spectra_7 for the Pimoroni Inky Impression 7.3 colour panel."
    },
    {
      "key": "ha_url",
      "type": "text",
      "required": true,
      "default": "http://homeassistant.local:8123",
      "description": "Home Assistant base URL for the companion sync script."
    },
    {
      "key": "ha_token",
      "type": "password",
      "required": true,
      "default": "",
      "description": "Home Assistant long-lived access token for the companion sync script. Do not commit live values."
    },
    {
      "key": "weather_entity",
      "type": "text",
      "required": false,
      "default": "weather.forecast_home",
      "description": "Home Assistant weather entity."
    },
    {
      "key": "person_entities",
      "type": "multi_string",
      "required": false,
      "default": "person.example",
      "description": "Comma-separated Home Assistant person entities."
    },
    {
      "key": "sonos_entities",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Comma-separated media_player entities."
    },
    {
      "key": "sonos_label",
      "type": "text",
      "required": false,
      "default": "Sonos",
      "description": "Label for the Sonos control card."
    },
    {
      "key": "light_entities",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Comma-separated light entities for compatible layouts/renderers. The current compact_grid sidecar does not render visible light cards."
    },
    {
      "key": "light_labels",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Optional comma-separated labels for light_entities."
    },
    {
      "key": "door_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Door or lock sensor entity."
    },
    {
      "key": "door_label",
      "type": "text",
      "required": false,
      "default": "Front door",
      "description": "Label for the door/security card."
    },
    {
      "key": "door_detail_label",
      "type": "text",
      "required": false,
      "default": "Security",
      "description": "Detail label for the door/security card."
    },
    {
      "key": "washer_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Laundry appliance status entity."
    },
    {
      "key": "washer_label",
      "type": "text",
      "required": false,
      "default": "Washer",
      "description": "Label for the washer card."
    },
    {
      "key": "washer_detail_label",
      "type": "text",
      "required": false,
      "default": "Utility",
      "description": "Detail label for the washer card."
    },
    {
      "key": "blind_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Cover or blind entity."
    },
    {
      "key": "blind_label",
      "type": "text",
      "required": false,
      "default": "Blinds",
      "description": "Label for the blind/cover card."
    },
    {
      "key": "blind_detail_label",
      "type": "text",
      "required": false,
      "default": "Position",
      "description": "Detail label for the blind/cover card."
    },
    {
      "key": "blind_open_position",
      "type": "text",
      "required": false,
      "default": "100",
      "description": "Position value that means fully open for this cover. Use 0 for inverted controllers."
    },
    {
      "key": "thermostat_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Climate or temperature entity."
    },
    {
      "key": "thermostat_label",
      "type": "text",
      "required": false,
      "default": "Climate",
      "description": "Label for the thermostat card."
    },
    {
      "key": "thermostat_detail_label",
      "type": "text",
      "required": false,
      "default": "Indoor",
      "description": "Detail label for the thermostat card."
    },
    {
      "key": "people_label",
      "type": "text",
      "required": false,
      "default": "People",
      "description": "Label for the grouped people/presence card."
    },
    {
      "key": "media_label",
      "type": "text",
      "required": false,
      "default": "Media",
      "description": "Label for the media summary card."
    },
    {
      "key": "generic_entities",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Comma-separated arbitrary HA or homelab entity IDs that can feed generic_entity slots."
    },
    {
      "key": "generic_labels",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Optional comma-separated labels aligned with generic_entities."
    },
    {
      "key": "generic_icons",
      "type": "multi_string",
      "required": false,
      "default": "",
      "description": "Optional comma-separated generic icon hints aligned with generic_entities."
    },
    {
      "key": "generic_status_colours",
      "type": "multi_string",
      "required": false,
      "default": "",
      "allowed_values": ["green", "yellow", "orange", "red", "blue", "white", "grey"],
      "description": "Optional comma-separated colour hints aligned with generic_entities."
    },
    {
      "key": "top_left_card_type",
      "type": "text",
      "required": false,
      "default": "weather",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the top-left fixed slot."
    },
    {
      "key": "top_left_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the top-left slot is generic_entity."
    },
    {
      "key": "top_left_label",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional label override for the top-left slot."
    },
    {
      "key": "top_left_detail_label",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional detail label override for the top-left slot."
    },
    {
      "key": "top_right_card_type",
      "type": "text",
      "required": false,
      "default": "indoor",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the top-right fixed slot."
    },
    {
      "key": "top_right_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the top-right slot is generic_entity."
    },
    {
      "key": "top_right_label",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional label override for the top-right slot."
    },
    {
      "key": "top_right_detail_label",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional detail label override for the top-right slot."
    },
    {
      "key": "status_1_card_type",
      "type": "text",
      "required": false,
      "default": "door_lock",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the first status-row fixed slot."
    },
    {
      "key": "status_1_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the first status slot is generic_entity."
    },
    {
      "key": "status_1_label",
      "type": "text",
      "required": false,
      "default": "Front door",
      "description": "Label override for the first status slot."
    },
    {
      "key": "status_1_detail_label",
      "type": "text",
      "required": false,
      "default": "Security",
      "description": "Detail label override for the first status slot."
    },
    {
      "key": "status_2_card_type",
      "type": "text",
      "required": false,
      "default": "cover",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the second status-row fixed slot."
    },
    {
      "key": "status_2_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the second status slot is generic_entity."
    },
    {
      "key": "status_2_label",
      "type": "text",
      "required": false,
      "default": "Blinds",
      "description": "Label override for the second status slot."
    },
    {
      "key": "status_2_detail_label",
      "type": "text",
      "required": false,
      "default": "Position",
      "description": "Detail label override for the second status slot."
    },
    {
      "key": "status_3_card_type",
      "type": "text",
      "required": false,
      "default": "washer",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the third status-row fixed slot."
    },
    {
      "key": "status_3_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the third status slot is generic_entity."
    },
    {
      "key": "status_3_label",
      "type": "text",
      "required": false,
      "default": "Washer",
      "description": "Label override for the third status slot."
    },
    {
      "key": "status_3_detail_label",
      "type": "text",
      "required": false,
      "default": "Utility",
      "description": "Detail label override for the third status slot."
    },
    {
      "key": "bottom_left_card_type",
      "type": "text",
      "required": false,
      "default": "person_group",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the bottom-left fixed slot."
    },
    {
      "key": "bottom_left_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the bottom-left slot is generic_entity."
    },
    {
      "key": "bottom_left_label",
      "type": "text",
      "required": false,
      "default": "People",
      "description": "Label override for the bottom-left slot."
    },
    {
      "key": "bottom_left_detail_label",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Detail label override for the bottom-left slot."
    },
    {
      "key": "bottom_right_card_type",
      "type": "text",
      "required": false,
      "default": "media",
      "allowed_values": ["weather", "indoor", "door_lock", "cover", "washer", "light_group", "person_group", "media", "generic_entity", "hidden"],
      "description": "Card template for the bottom-right fixed slot."
    },
    {
      "key": "bottom_right_entity",
      "type": "text",
      "required": false,
      "default": "",
      "description": "Optional entity ID used when the bottom-right slot is generic_entity."
    },
    {
      "key": "bottom_right_label",
      "type": "text",
      "required": false,
      "default": "Media",
      "description": "Label override for the bottom-right slot."
    },
    {
      "key": "bottom_right_detail_label",
      "type": "text",
      "required": false,
      "default": "Sonos",
      "description": "Detail label override for the bottom-right slot."
    }
  ],
  "sidecar": {
    "supported": true,
    "renderer": "scripts/render_colour_dashboard.py",
    "output": "scripts/tmp/sidecar_colour_dashboard_next.png",
    "payload_input": "TRMNL merge_variables JSON payload, such as plugins/trmnl-ha-dashboard/payload.example.json or a live payload written by scripts/trmnl_ha_dashboard.py.",
    "canonical_reference": "scripts/tmp/sidecar_colour_dashboard_proof_2026-05-01.png",
    "notes": "The sidecar honors this field contract while preserving the accepted 2026-05-01 icon-led seven-colour proof style."
  }
}
