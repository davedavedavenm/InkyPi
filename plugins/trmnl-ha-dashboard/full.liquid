{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}
{% assign idle_count = sonos | where: "state", "idle" | size %}
{% assign c = weather.condition | downcase %}
{% assign weather_icon = "SUN" %}
{% if c contains "rain" or c contains "drizzle" or c contains "shower" %}
  {% assign weather_icon = "RAIN" %}
{% elsif c contains "snow" or c contains "sleet" %}
  {% assign weather_icon = "SNOW" %}
{% elsif c contains "thunder" %}
  {% assign weather_icon = "STORM" %}
{% elsif c contains "fog" or c contains "mist" %}
  {% assign weather_icon = "FOG" %}
{% elsif c contains "cloud" or c contains "overcast" %}
  {% assign weather_icon = "CLOUD" %}
{% endif %}

<!--
  Colour-first layout for the live Inky Impression 7.3 / Spectra panel.
  Use saturated ACeP-safe blocks: black, white, red, yellow, blue, orange.
  Avoid subtle gradients and gray-heavy sections; they collapse badly on the panel.
-->

<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Helvetica Neue','Segoe UI',Arial,sans-serif; background:#ffffff; }
</style>

<div style="width:800px;height:480px;background:#ffffff;color:#000000;display:flex;flex-direction:column;overflow:hidden;">

  <div style="height:48px;background:#000000;color:#ffffff;display:flex;align-items:center;justify-content:space-between;padding:0 22px;border-bottom:4px solid #FFFF00;">
    <div style="font-size:15px;font-weight:900;text-transform:uppercase;letter-spacing:1px;">Home Dashboard</div>
    <div style="font-size:13px;font-weight:900;color:#FFFF00;text-transform:uppercase;">{{ updated_at }}</div>
  </div>

  <div style="height:300px;display:grid;grid-template-columns:250px 1fr;border-bottom:4px solid #000000;">

    <div style="background:#0000FF;color:#ffffff;padding:18px 20px;display:flex;flex-direction:column;justify-content:space-between;border-right:4px solid #000000;">
      <div>
        <div style="display:inline-block;background:#FFFF00;color:#000000;padding:5px 10px;font-size:12px;font-weight:900;text-transform:uppercase;">Weather</div>
        <div style="font-size:34px;font-weight:900;margin-top:14px;line-height:1;">{{ weather_icon }}</div>
        <div style="font-size:88px;font-weight:900;line-height:0.9;margin-top:8px;">{{ weather.temperature | round }}<span style="font-size:34px;vertical-align:top;">deg</span></div>
        <div style="font-size:18px;font-weight:900;line-height:1.1;margin-top:8px;">{{ weather.condition_label }}</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        <div style="background:#ffffff;color:#000000;padding:8px;">
          <div style="font-size:10px;font-weight:900;text-transform:uppercase;">Humidity</div>
          <div style="font-size:22px;font-weight:900;">{{ weather.humidity }}%</div>
        </div>
        <div style="background:#ffffff;color:#000000;padding:8px;">
          <div style="font-size:10px;font-weight:900;text-transform:uppercase;">Wind</div>
          <div style="font-size:22px;font-weight:900;">{{ weather.wind_speed | round }}</div>
        </div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;background:#ffffff;">
      <div style="height:88px;display:grid;grid-template-columns:1fr 1fr;border-bottom:4px solid #000000;">
        {% for person in people %}
          <div style="padding:14px 18px;background:{% if person.state == 'home' %}#FFFF00{% else %}#FF0000{% endif %};color:{% if person.state == 'home' %}#000000{% else %}#ffffff{% endif %};{% unless forloop.last %}border-right:4px solid #000000;{% endunless %}">
            <div style="font-size:12px;font-weight:900;text-transform:uppercase;">{{ person.name }}</div>
            <div style="font-size:34px;font-weight:900;line-height:1;margin-top:8px;">{% if person.state == 'home' %}Home{% else %}Away{% endif %}</div>
          </div>
        {% endfor %}
      </div>

      <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;">
        <div style="padding:16px 18px;border-right:2px solid #000000;border-bottom:2px solid #000000;background:{% if home.door_locked %}#ffffff{% else %}#FF0000{% endif %};color:{% if home.door_locked %}#000000{% else %}#ffffff{% endif %};">
          <div style="font-size:12px;font-weight:900;text-transform:uppercase;">Door</div>
          <div style="font-size:34px;font-weight:900;line-height:1;margin-top:10px;">{% if home.door_locked %}Locked{% else %}Open{% endif %}</div>
        </div>
        <div style="padding:16px 18px;border-bottom:2px solid #000000;background:{% if home.washer_running %}#FFA500{% else %}#ffffff{% endif %};color:#000000;">
          <div style="font-size:12px;font-weight:900;text-transform:uppercase;">Washer</div>
          <div style="font-size:34px;font-weight:900;line-height:1;margin-top:10px;">{% if home.washer_running %}Running{% else %}Off{% endif %}</div>
        </div>
        <div style="padding:16px 18px;border-right:2px solid #000000;background:#000000;color:#ffffff;">
          <div style="font-size:12px;font-weight:900;text-transform:uppercase;color:#FFFF00;">Lounge</div>
          <div style="font-size:34px;font-weight:900;line-height:1;margin-top:10px;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}C{% else %}--{% endif %}</div>
        </div>
        <div style="padding:16px 18px;background:{% if home.blinds_open %}#FFFF00{% else %}#000000{% endif %};color:{% if home.blinds_open %}#000000{% else %}#ffffff{% endif %};">
          <div style="font-size:12px;font-weight:900;text-transform:uppercase;">Blinds</div>
          <div style="font-size:34px;font-weight:900;line-height:1;margin-top:10px;">{% if home.blind_position == "unavailable" or home.blind_position == nil %}--{% elsif home.blinds_open %}Open{% else %}Closed{% endif %}</div>
        </div>
      </div>
    </div>
  </div>

  <div style="height:132px;display:grid;grid-template-columns:150px 1fr 210px;background:{% if active_sonos %}#FFA500{% else %}#FF0000{% endif %};color:{% if active_sonos %}#000000{% else %}#ffffff{% endif %};">
    <div style="display:flex;align-items:center;justify-content:center;border-right:4px solid #000000;background:#FFFF00;color:#000000;">
      <div style="font-size:28px;font-weight:900;text-transform:uppercase;line-height:1;text-align:center;">{% if active_sonos %}Music{% else %}Quiet{% endif %}</div>
    </div>
    <div style="padding:16px 20px;min-width:0;">
      <div style="font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:1px;">Sonos</div>
      {% if active_sonos %}
        <div style="font-size:30px;font-weight:900;line-height:1.05;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:8px;">{{ active_sonos.title }}</div>
        <div style="font-size:16px;font-weight:900;line-height:1.1;margin-top:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ active_sonos.artist }}{% if active_sonos.room %} - {{ active_sonos.room }}{% endif %}</div>
      {% else %}
        <div style="font-size:30px;font-weight:900;line-height:1.05;margin-top:8px;">No Music Playing</div>
        <div style="font-size:16px;font-weight:900;line-height:1.1;margin-top:7px;">{{ idle_count }} rooms idle</div>
      {% endif %}
    </div>
    <div style="padding:14px 14px;border-left:4px solid #000000;display:flex;flex-wrap:wrap;align-content:center;justify-content:flex-end;gap:6px;">
      {% for room in sonos %}
        <div style="font-size:10px;font-weight:900;text-transform:uppercase;padding:6px 8px;background:{% if room.state == 'playing' or room.state == 'paused' %}#000000{% else %}#ffffff{% endif %};color:{% if room.state == 'playing' or room.state == 'paused' %}#FFFF00{% else %}#000000{% endif %};border:2px solid #000000;">{{ room.room | truncate: 9, "" }}</div>
      {% endfor %}
    </div>
  </div>

</div>
