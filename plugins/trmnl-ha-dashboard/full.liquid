{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}
{% assign idle_count = sonos | where: "state", "idle" | size %}
{% assign c = weather.condition | downcase %}
{% assign weather_icon = "Sun" %}
{% if c contains "rain" or c contains "drizzle" or c contains "shower" %}
  {% assign weather_icon = "Rain" %}
{% elsif c contains "snow" or c contains "sleet" %}
  {% assign weather_icon = "Snow" %}
{% elsif c contains "thunder" %}
  {% assign weather_icon = "Storm" %}
{% elsif c contains "fog" or c contains "mist" %}
  {% assign weather_icon = "Fog" %}
{% elsif c contains "cloud" or c contains "overcast" %}
  {% assign weather_icon = "Cloud" %}
{% endif %}

<!-- Home Assistant compact-grid style for the live Inky Impression / Spectra colour panel. -->

<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Helvetica Neue','Segoe UI',Arial,sans-serif; background:#f8f5ed; }
</style>

<div style="width:800px;height:480px;background:#f8f5ed;color:#111111;padding:16px 18px 14px;display:flex;flex-direction:column;overflow:hidden;">

  <div style="height:52px;display:grid;grid-template-columns:1fr auto;align-items:start;border-bottom:1px solid #888888;padding-bottom:10px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:28px;height:28px;background:#2f3d42;color:#ffffff;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;border-radius:3px;">H</div>
      <div>
        <div style="font-size:15px;font-weight:900;text-transform:uppercase;letter-spacing:0.5px;">Home Assistant</div>
        <div style="font-size:11px;font-weight:700;color:#56666a;margin-top:2px;">TRMNL colour display</div>
      </div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:34px;line-height:0.9;font-weight:300;">{{ updated_at | slice: -5, 5 }}</div>
      <div style="font-size:11px;font-weight:700;color:#333333;margin-top:5px;">{{ updated_at }}</div>
    </div>
  </div>

  <div style="height:82px;display:grid;grid-template-columns:1.3fr 1fr 1fr;gap:10px;margin-top:10px;">
    <div style="background:#FFFF00;border:1px solid #777777;border-radius:6px;padding:12px 14px;display:grid;grid-template-columns:auto 1fr;gap:12px;align-items:center;">
      <div style="width:44px;height:44px;border-radius:50%;background:#ffd43b;border:2px solid #111111;"></div>
      <div>
        <div style="font-size:24px;font-weight:800;line-height:1;">{{ weather.temperature | round: 1 }}C</div>
        <div style="font-size:12px;font-weight:700;margin-top:4px;">{{ weather.condition_label }}</div>
      </div>
    </div>
    <div style="background:#0000FF;color:#ffffff;border:1px solid #777777;border-radius:6px;padding:12px 14px;">
      <div style="font-size:11px;font-weight:900;text-transform:uppercase;color:#ffffff;">Humidity</div>
      <div style="font-size:28px;font-weight:800;line-height:1.1;margin-top:8px;">{{ weather.humidity }}%</div>
    </div>
    <div style="background:#00FF00;border:1px solid #777777;border-radius:6px;padding:12px 14px;">
      <div style="font-size:11px;font-weight:900;text-transform:uppercase;color:#000000;">Wind</div>
      <div style="font-size:28px;font-weight:800;line-height:1.1;margin-top:8px;">{{ weather.wind_speed | round }} km/h</div>
    </div>
  </div>

  <div style="flex:1;display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,1fr);gap:10px;margin-top:10px;min-height:0;">
    {% for person in people limit:2 %}
      <div style="background:#ffffff;border:1px solid #777777;border-radius:6px;display:grid;grid-template-columns:38px 1fr;overflow:hidden;">
        <div style="background:{% if forloop.index == 1 %}#FFFF00{% else %}#00FF00{% endif %};"></div>
        <div style="padding:12px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="font-size:13px;font-weight:900;">{{ person.name }}</div>
          <div style="font-size:28px;font-weight:800;line-height:1;">{% if person.state == 'home' %}Home{% else %}Away{% endif %}</div>
          <div style="font-size:10px;font-weight:800;text-transform:uppercase;color:#555555;">Presence</div>
        </div>
      </div>
    {% endfor %}

    <div style="background:#ffffff;border:1px solid #777777;border-radius:6px;display:grid;grid-template-columns:38px 1fr;overflow:hidden;">
      <div style="background:{% if home.door_locked %}#0000FF{% else %}#FF0000{% endif %};"></div>
      <div style="padding:12px;display:flex;flex-direction:column;justify-content:space-between;">
        <div style="font-size:13px;font-weight:900;">Front Door</div>
        <div style="font-size:28px;font-weight:800;line-height:1;">{% if home.door_locked %}Locked{% else %}Open{% endif %}</div>
        <div style="font-size:10px;font-weight:800;text-transform:uppercase;color:#555555;">Security</div>
      </div>
    </div>

    <div style="background:#ffffff;border:1px solid #777777;border-radius:6px;display:grid;grid-template-columns:38px 1fr;overflow:hidden;">
      <div style="background:#FF0000;"></div>
      <div style="padding:12px;display:flex;flex-direction:column;justify-content:space-between;">
        <div style="font-size:13px;font-weight:900;">Thermostat</div>
        <div style="font-size:28px;font-weight:800;line-height:1;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}C{% else %}--{% endif %}</div>
        <div style="font-size:10px;font-weight:800;text-transform:uppercase;color:#555555;">Lounge temp</div>
      </div>
    </div>

    <div style="background:#ffffff;border:1px solid #777777;border-radius:6px;display:grid;grid-template-columns:38px 1fr;overflow:hidden;">
      <div style="background:#FFA500;"></div>
      <div style="padding:12px;display:flex;flex-direction:column;justify-content:space-between;">
        <div style="font-size:13px;font-weight:900;">Washer</div>
        <div style="font-size:28px;font-weight:800;line-height:1;">{% if home.washer_running %}Running{% else %}Off{% endif %}</div>
        <div style="font-size:10px;font-weight:800;text-transform:uppercase;color:#555555;">Utility</div>
      </div>
    </div>

    <div style="background:#ffffff;border:1px solid #777777;border-radius:6px;display:grid;grid-template-columns:38px 1fr;overflow:hidden;">
      <div style="background:#00FF00;"></div>
      <div style="padding:12px;display:flex;flex-direction:column;justify-content:space-between;">
        <div style="font-size:13px;font-weight:900;">Blinds</div>
        <div style="font-size:28px;font-weight:800;line-height:1;">{% if home.blind_position == "unavailable" or home.blind_position == nil %}--{% elsif home.blinds_open %}Open{% else %}Closed{% endif %}</div>
        <div style="font-size:10px;font-weight:800;text-transform:uppercase;color:#555555;">Position</div>
      </div>
    </div>

    <div style="grid-column:span 2;background:#ffffff;border:1px solid #777777;border-radius:6px;padding:12px;display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;border-left:38px solid #FFFF00;">
      <div style="min-width:0;">
        <div style="font-size:13px;font-weight:900;">Sonos</div>
        {% if active_sonos %}
          <div style="font-size:24px;font-weight:800;line-height:1.05;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:6px;">{{ active_sonos.title }}</div>
          <div style="font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:4px;">{{ active_sonos.artist }}{% if active_sonos.room %} - {{ active_sonos.room }}{% endif %}</div>
        {% else %}
          <div style="font-size:24px;font-weight:800;line-height:1.05;margin-top:6px;">No Music</div>
          <div style="font-size:12px;font-weight:700;margin-top:4px;">{{ idle_count }} rooms idle</div>
        {% endif %}
      </div>
      <div style="width:56px;height:56px;border-radius:50%;background:#ffd43b;border:2px solid #111111;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:900;">♪</div>
    </div>
  </div>

  <div style="height:54px;margin-top:12px;background:#6f837a;color:#ffffff;border-radius:5px;display:grid;grid-template-columns:repeat(6,1fr);align-items:center;border:1px solid #555555;overflow:hidden;">
    <div style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#516d74;">
      <div style="font-size:18px;font-weight:900;">H</div><div style="font-size:10px;font-weight:800;">Home</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <div style="font-size:18px;font-weight:900;">L</div><div style="font-size:10px;font-weight:800;">Lights</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <div style="font-size:18px;font-weight:900;">C</div><div style="font-size:10px;font-weight:800;">Climate</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <div style="font-size:18px;font-weight:900;">S</div><div style="font-size:10px;font-weight:800;">Security</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <div style="font-size:18px;font-weight:900;">M</div><div style="font-size:10px;font-weight:800;">Media</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <div style="font-size:18px;font-weight:900;">...</div><div style="font-size:10px;font-weight:800;">More</div>
    </div>
  </div>

</div>
